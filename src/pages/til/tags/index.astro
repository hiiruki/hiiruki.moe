---
import { getAllTil, getUniqueTilTagsWithCount } from "@/data/til";
import PageLayout from "@/layouts/Base.astro";

const allTil = await getAllTil();
const allTags = getUniqueTilTagsWithCount(allTil);

const meta = {
	description: "A list of all the topics I've written about in my TIL notes",
	title: "All TIL Tags",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">TIL Tags</h1>
	<ul class="space-y-4">
		{
			allTags.map(([tag, val]) => (
				<li class="flex items-center gap-x-2">
					<a
						class="cactus-link inline-block"
						href={`/til/tags/${tag}/`}
						title={`View TILs with the tag: ${tag}`}
					>
						&#35;{tag}
					</a>
					<span class="inline-block">
						- {val} Item{val > 1 && "s"}
					</span>
				</li>
			))
		}
	</ul>
</PageLayout>
