---
import { execSync } from "node:child_process";

// Default values in case git commands fail
let commitHash = "unknown";
let commitTimestamp = "";
let commitMessage = "No latest commit found.";
let commitAuthor = "Unknown";
let commitBranch = "main";
let commitDateDetailed = "";
let commitTimeAgo = "";
let totalFilesChanged = 0;
let totalInsertions = 0;
let totalDeletions = 0;
let totalLines = 0;
let changedFiles: { path: string; insertions: number; deletions: number }[] = [];

try {
	commitHash = execSync("git rev-parse --short HEAD").toString().trim();
	commitTimestamp = execSync("git show -s --format=%cd --date=format:'%Y-%m-%d %H:%M' HEAD").toString().trim();
	
	commitMessage = execSync("git log -1 --pretty=%B").toString().trim();
	commitAuthor = execSync("git log -1 --pretty=%an").toString().trim();
	commitBranch = import.meta.env.CF_PAGES_BRANCH || execSync("git rev-parse --abbrev-ref HEAD").toString().trim();
	
	// e.g. "Mar 7, 2026, 01:51 PM GMT+7"
	commitDateDetailed = execSync("git log -1 --pretty='%cd' --date=format:'%b %e, %Y, %I:%M %p GMT+7'").toString().trim();
	
	// e.g. "1 week ago"
	commitTimeAgo = execSync("git log -1 --pretty=%ar").toString().trim();
	
	// Get numstat without the commit message headers to calculate changed files and lines
	const numstatRaw = execSync("git show --numstat --format=\"\" HEAD").toString().trim();
	if (numstatRaw) {
		const lines = numstatRaw.split('\n');
		lines.forEach((line) => {
			const parts = line.split('\t');
			if (parts.length >= 3) {
				const ins = parseInt(parts[0] as string, 10) || 0;
				const del = parseInt(parts[1] as string, 10) || 0;
				const file = parts[2] as string;
				
				totalInsertions += ins;
				totalDeletions += del;
				totalFilesChanged += 1;
				totalLines += (ins + del);
				
				changedFiles.push({ path: file, insertions: ins, deletions: del });
			}
		});
	}
} catch (e) {
	// Fallback to defaults if child_process fails
}
