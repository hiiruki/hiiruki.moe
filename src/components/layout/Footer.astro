	// 2. Fetch Network Trace & DC Metadata
	async function fetchNetworkInfo() {
		try {
			const [traceRes, dcRes] = await Promise.all([
				fetch("/cdn-cgi/trace"),
				fetch("/DC-Colos.json"),
			]);

			if (!traceRes.ok || !dcRes.ok) throw new Error("Network response was not ok");

			const text = await traceRes.text();
			const dcColos = await dcRes.json();
			const lines = text.split("\n");

			let ip = "Unknown";
			let colo = "Unknown";

			lines.forEach((line) => {
				const parts = line.split("=");
				if (parts.length >= 2) {
					const key = parts[0] ? parts[0].trim() : "";
					const value = parts[1] ? parts[1].trim() : "";
					if (key === "ip") ip = value;
					if (key === "colo") colo = value;
				}
			});

			const dcInfo = dcColos[colo];
			const networkEl = document.getElementById("network-info");

			if (networkEl && dcInfo) {
				networkEl.innerHTML = `
					<button id="network-btn" class="w-full text-left text-gray-800 dark:text-gray-300 hover:text-green-700 dark:hover:text-[#ccff00] transition-colors focus:outline-none">
						${colo}, ${dcInfo.cca2} (${dcInfo.country})
					</button>
					<div id="network-card" class="absolute bottom-full mb-3 left-0 hidden w-64 bg-white dark:bg-[#1a1a1a] shadow-xl rounded-xl border border-gray-200 dark:border-gray-800 p-5 z-50">
						<div class="flex flex-col space-y-3 text-xs">
							<div class="flex justify-between items-start gap-2 border-b border-gray-100 dark:border-gray-800 pb-2">
								<span class="text-gray-500 whitespace-nowrap">Data Center</span> 
								<span class="text-gray-800 dark:text-gray-300 font-bold text-right">${dcInfo.name}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Location</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${dcInfo.city}, ${dcInfo.country}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Region</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${dcInfo.region}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Coordinates</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${dcInfo.lat}, ${dcInfo.lon}</span>
							</div>
							<div class="flex justify-between items-start gap-2 border-t border-gray-100 dark:border-gray-800 pt-2 mt-1">
								<span class="text-gray-500 whitespace-nowrap">Your IP Address</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${ip}</span>
							</div>
						</div>
					</div>
				`;

				const btn = document.getElementById("network-btn");
				const card = document.getElementById("network-card");

				btn.addEventListener("click", (e) => {
					e.stopPropagation();
					card.classList.toggle("hidden");
				});

				// Close the card when clicking outside
				document.addEventListener("click", (e) => {
					if (!networkEl.contains(e.target)) {
						card.classList.add("hidden");
					}
				});
			} else if (networkEl) {
				networkEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		} catch (error) {
			console.error("Failed to fetch network info", error);
			const networkEl = document.getElementById("network-info");
			if (networkEl) {
				networkEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		}
	}
	fetchNetworkInfo();

	// 3. Fetch Uptime
	async function fetchUptime() {
		try {
			const res = await fetch("https://status.hiiruki.moe/index.json");
			const json = await res.json();
			const state =
				json.data && json.data.attributes && json.data.attributes.aggregate_state
					? json.data.attributes.aggregate_state
					: "operational";

			let pingColor = "bg-green-400";
			let dotColor = "bg-green-500";
			let statusText = "All systems normal";

			if (state === "downtime" || state === "degraded") {
				pingColor = "bg-red-400";
				dotColor = "bg-red-500";
				statusText = "Some services are down";
			} else if (state === "maintenance") {
				pingColor = "bg-yellow-400";
				dotColor = "bg-yellow-500";
				statusText = "System maintenance";
			}

			const uptimeEl = document.getElementById("uptime-info");
			if (uptimeEl) {
				uptimeEl.innerHTML =
					'<a href="https://status.hiiruki.moe/" target="_blank" rel="noopener noreferrer" class="group flex items-center space-x-2">' +
					'<span class="relative flex h-2.5 w-2.5">' +
					'<span class="absolute inline-flex h-full w-full animate-ping rounded-full ' +
					pingColor +
					' opacity-75"></span>' +
					'<span class="relative inline-flex h-2.5 w-2.5 rounded-full ' +
					dotColor +
					'"></span>' +
					"</span>" +
					'<span class="text-gray-800 transition-colors group-hover:text-green-700 dark:text-gray-300 dark:group-hover:text-[#ccff00]">' +
					statusText +
					"</span>" +
					"</a>";
			}
		} catch (e) {
			const uptimeEl = document.getElementById("uptime-info");
			if (uptimeEl) {
				uptimeEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		}
	}
	fetchUptime();
</script>
