	// 2. Fetch Network Trace & DC Metadata
	async function fetchNetworkInfo() {
		try {
			const [traceRes, dcRes] = await Promise.all([
				fetch("/cdn-cgi/trace"),
				fetch("/DC-Colos.json"),
			]);

			if (!traceRes.ok || !dcRes.ok) throw new Error("Network response was not ok");

			const text = await traceRes.text();
			const dcColos = await dcRes.json();
			const lines = text.split("\n");

			let ip = "Unknown";
			let colo = "Unknown";

			lines.forEach((line) => {
				const parts = line.split("=");
				if (parts.length >= 2) {
					const key = parts[0] ? parts[0].trim() : "";
					const value = parts[1] ? parts[1].trim() : "";
					if (key === "ip") ip = value;
					if (key === "colo") colo = value;
				}
			});

			const dcInfo = dcColos[colo];
			const networkEl = document.getElementById("network-info");

			if (networkEl && dcInfo) {
				const displayCountry = dcInfo.country || dcInfo.name;
				const displayLocation = dcInfo.city && dcInfo.city !== displayCountry 
					? `${dcInfo.city}, ${displayCountry}` 
					: displayCountry;

				networkEl.innerHTML = `
					<div class="cursor-pointer text-gray-800 dark:text-gray-300 hover:text-accent transition-colors pb-1">
						${colo}, ${dcInfo.cca2} (${displayCountry})
					</div>
					<div class="absolute bottom-full mb-3 left-0 sm:left-0 sm:right-auto flex flex-col w-[280px] sm:w-64 bg-white dark:bg-[#1a1a1a] shadow-xl rounded-xl border border-gray-200 dark:border-gray-800 p-5 z-50 opacity-0 invisible translate-y-2 transition-all duration-300 delay-200 group-hover/network:visible group-hover/network:opacity-100 group-hover/network:translate-y-0 group-hover/network:delay-0 before:absolute before:-bottom-3 before:left-0 before:h-3 before:w-full">
						<div class="flex flex-col space-y-3 text-xs cursor-default">
							<div class="flex justify-between items-start gap-2 border-b border-gray-100 dark:border-gray-800 pb-2">
								<span class="text-gray-500 whitespace-nowrap">Data Center</span> 
								<span class="text-gray-800 dark:text-gray-300 font-bold text-right">${colo}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Location</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${displayLocation}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Region</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${dcInfo.region}</span>
							</div>
							<div class="flex justify-between items-start gap-2">
								<span class="text-gray-500 whitespace-nowrap">Coordinates</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${dcInfo.lat}, ${dcInfo.lon}</span>
							</div>
							<div class="flex justify-between items-start gap-2 border-t border-gray-100 dark:border-gray-800 pt-2 mt-1">
								<span class="text-gray-500 whitespace-nowrap">Your IP Address</span> 
								<span class="text-gray-800 dark:text-gray-300 text-right">${ip}</span>
							</div>
						</div>
					</div>
				`;
			} else if (networkEl) {
				networkEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		} catch (error) {
			console.error("Failed to fetch network info", error);
			const networkEl = document.getElementById("network-info");
			if (networkEl) {
				networkEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		}
	}
	fetchNetworkInfo();

	// 3. Fetch Uptime
	async function fetchUptime() {
		try {
			const res = await fetch("https://status.hiiruki.moe/index.json");
			const json = await res.json();
			const state =
				json.data && json.data.attributes && json.data.attributes.aggregate_state
					? json.data.attributes.aggregate_state
					: "operational";

			let pingColor = "bg-green-400";
			let dotColor = "bg-green-500";
			let statusText = "All systems normal";

			if (state === "downtime" || state === "degraded") {
				pingColor = "bg-red-400";
				dotColor = "bg-red-500";
				statusText = "Some services are down";
			} else if (state === "maintenance") {
				pingColor = "bg-yellow-400";
				dotColor = "bg-yellow-500";
				statusText = "System maintenance";
			}

			const uptimeEl = document.getElementById("uptime-info");
			if (uptimeEl) {
				uptimeEl.innerHTML =
					'<a href="https://status.hiiruki.moe/" target="_blank" rel="noopener noreferrer" class="group flex items-center space-x-2">' +
					'<span class="relative flex h-2.5 w-2.5">' +
					'<span class="absolute inline-flex h-full w-full animate-ping rounded-full ' +
					pingColor +
					' opacity-75"></span>' +
					'<span class="relative inline-flex h-2.5 w-2.5 rounded-full ' +
					dotColor +
					'"></span>' +
					"</span>" +
					'<span class="text-gray-800 transition-colors group-hover:text-accent dark:text-gray-300 dark:group-hover:text-accent">' +
					statusText +
					"</span>" +
					"</a>";
			}

			// Populate Hover Card with exact service uptimes
			const resourcesList = document.getElementById("uptime-resources-list");
			if (resourcesList && json.included) {
				const resources = json.included
					.filter((item) => item.type === "status_page_resource" && item.attributes)
					.map((item) => ({
						name: item.attributes.public_name,
						availability: (item.attributes.availability * 100).toFixed(2),
						status: item.attributes.status,
					}));

				if (resources.length > 0) {
					resourcesList.innerHTML = resources
						.map((res) => {
							let resColor = "text-green-500 dark:text-green-400";
							if (res.status === "downtime" || res.status === "degraded") {
								resColor = "text-red-500 dark:text-red-400";
							} else if (res.status === "maintenance") {
								resColor = "text-yellow-500 dark:text-yellow-400";
							}

							return (
								'<div class="flex items-center justify-between">' +
								'<span class="text-gray-800 dark:text-gray-200 font-medium truncate pr-2">' +
								res.name +
								"</span>" +
								'<span class="font-mono ' +
								resColor +
								'">' +
								res.availability +
								"%</span>" +
								"</div>"
							);
						})
						.join("");
				} else {
					resourcesList.innerHTML = '<span class="text-gray-500 italic">No resources found.</span>';
				}
			}
		} catch (e) {
			const uptimeEl = document.getElementById("uptime-info");
			if (uptimeEl) {
				uptimeEl.innerHTML = '<span class="text-gray-800 dark:text-gray-300">Unavailable</span>';
			}
		}
	}
	fetchUptime();

	// 4. Update Commit Time Ago dynamically
	function updateCommitTimeAgo() {
		const elements = document.querySelectorAll(".commit-time-ago");
		if (!elements.length) return;

		elements.forEach((el) => {
			const timestamp = parseInt(el.getAttribute("data-timestamp") || "0", 10);
			if (!timestamp) return;

			const diffSec = Math.floor(Date.now() / 1000) - timestamp;
			let timeString = "";

			if (diffSec < 60) {
				timeString = "just now";
			} else if (diffSec < 3600) {
				const mins = Math.floor(diffSec / 60);
				timeString = `${mins} minute${mins !== 1 ? "s" : ""} ago`;
			} else if (diffSec < 86400) {
				const hours = Math.floor(diffSec / 3600);
				timeString = `${hours} hour${hours !== 1 ? "s" : ""} ago`;
			} else {
				const days = Math.floor(diffSec / 86400);
				if (days < 7) {
					timeString = `${days} day${days !== 1 ? "s" : ""} ago`;
				} else if (days < 30) {
					const weeks = Math.floor(days / 7);
					timeString = `${weeks} week${weeks !== 1 ? "s" : ""} ago`;
				} else if (days < 365) {
					const months = Math.floor(days / 30);
					timeString = `${months} month${months !== 1 ? "s" : ""} ago`;
				} else {
					const years = Math.floor(days / 365);
					timeString = `${years} year${years !== 1 ? "s" : ""} ago`;
				}
			}

			el.textContent = timeString;
		});
	}
	updateCommitTimeAgo();
	setInterval(updateCommitTimeAgo, 60000); // Update every minute

	// 5. Calculate Client-Side Load Time
	window.addEventListener('load', () => {
		setTimeout(() => {
			try {
				const loadTimeEl = document.getElementById("load-time-info");
				if (!loadTimeEl) return;
				
				const [navEntry] = performance.getEntriesByType('navigation');
				if (navEntry) {
					const loadTime = Math.round(navEntry.loadEventEnd - navEntry.startTime);
					loadTimeEl.textContent = loadTime + "ms";
				} else {
					const perfData = window.performance.timing;
					const pageLoadTime = perfData.loadEventEnd - perfData.navigationStart;
					loadTimeEl.textContent = pageLoadTime + "ms";
				}
			} catch (e) {
				console.error("Could not calculate load time", e);
			}
		}, 0);
	});
</script>
