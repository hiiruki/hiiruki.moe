---
import { execSync } from "node:child_process";

let commitHash = "bd9bf04";
let commitTimestamp = "";
try {
	commitHash = execSync("git rev-parse --short HEAD").toString().trim();
	commitTimestamp = execSync("git show -s --format=%cd --date=format:'%Y-%m-%d %H:%M' HEAD")
		.toString()
		.trim();
} catch (e) {
	// Fallback to hardcoded hash if child_process fails
}
