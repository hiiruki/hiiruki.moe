---
const username = import.meta.env.LASTFM_USERNAME || "";
const apiKey = import.meta.env.LASTFM_API_KEY || "";
---

<div id="lastfm-card" class="mt-8 relative hidden items-center gap-4 group/lastfm w-max" data-username={username} data-apikey={apiKey}>
	<img
		id="lastfm-art"
		src=""
		alt="Album Art"
		class="h-16 w-16 shrink-0 rounded-xl bg-black/10 object-cover shadow-sm dark:bg-white/10"
	/>
	<div class="flex flex-col justify-center gap-1.5">
		<div class="flex items-center gap-2">
			<div id="lastfm-status-dot" class="h-1.5 w-1.5 rounded-full bg-amber-500"></div>
			<span
				id="lastfm-status"
				class="text-[10px] font-bold tracking-widest text-amber-500 uppercase font-mono"
				>PAUSED</span
			>
		</div>
		<a
			id="lastfm-link"
			href="#"
			target="_blank"
			rel="noopener noreferrer"
			class="text-sm font-mono opacity-80 hover:opacity-100 hover:text-accent transition-colors truncate max-w-[200px] sm:max-w-[300px]"
		>
			<span id="lastfm-track" class="truncate">Track</span> - <span id="lastfm-artist" class="truncate">Artist</span>
		</a>
	</div>

	<!-- Hover Card (Discord style) -->
	<div class="absolute top-full left-0 sm:left-auto sm:right-auto mt-3 flex w-[280px] sm:w-[340px] flex-col bg-[#111214] dark:bg-[#111214] shadow-2xl rounded-xl border border-[#313338] p-4 z-50 cursor-default opacity-0 invisible translate-y-2 transition-all duration-300 delay-200 group-hover/lastfm:visible group-hover/lastfm:opacity-100 group-hover/lastfm:translate-y-0 group-hover/lastfm:delay-0 before:absolute before:-top-3 before:left-0 before:h-3 before:w-full">
		<h4 id="hover-status-title" class="font-bold text-[10px] tracking-widest text-[#B5BAC1] uppercase mb-3">NOT PLAYING</h4>

		<div class="flex items-center gap-3 mb-3 relative">
			<img id="hover-art" src="" class="h-14 w-14 rounded-md object-cover bg-[#2b2d31] shrink-0 shadow-md" />
			<div class="flex flex-col min-w-0 justify-center">
				<span id="hover-track" class="font-bold text-sm text-white truncate">Track</span>
				<span id="hover-artist" class="text-xs text-[#B5BAC1] truncate mt-0.5">Artist</span>
			</div>
		</div>

		<div class="bg-[#2b2d31] rounded-lg p-3 mb-3 border border-[#1e1f22] flex items-center">
			<p id="hover-time" class="text-xs text-[#DBDEE1]">Last listened...</p>
		</div>

		<div class="border-t border-[#313338] pt-3 mt-1">
			<button id="open-history-btn" class="w-full text-left font-bold text-[10px] tracking-widest text-[#B5BAC1] uppercase hover:text-white transition-colors focus:outline-none">
				CLICK TO OPEN LISTENING HISTORY
			</button>
		</div>
		
		<div id="history-dropdown" class="hidden flex-col space-y-1 mt-3 pt-3 border-t border-[#313338] max-h-48 overflow-y-auto pr-1 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
			<div id="lastfm-recent-list" class="flex flex-col space-y-1">
				<span class="text-xs text-[#B5BAC1] italic">Loading history...</span>
			</div>
		</div>
	</div>
</div>

<div id="lastfm-skeleton" class="mt-8 flex animate-pulse items-center gap-4">
	<div class="h-16 w-16 shrink-0 rounded-xl bg-black/10 dark:bg-white/10"></div>
	<div class="flex w-full flex-col justify-center gap-2">
		<div class="flex items-center gap-2">
			<div class="h-1.5 w-1.5 rounded-full bg-black/10 dark:bg-white/10"></div>
			<div class="h-2 w-16 rounded bg-black/10 dark:bg-white/10"></div>
		</div>
		<div class="h-3 w-48 rounded bg-black/10 dark:bg-white/10"></div>
	</div>
</div>

<script>
	async function fetchLastFm() {
		try {
			const skeleton = document.getElementById("lastfm-skeleton");
			const card = document.getElementById("lastfm-card");

			const username = card?.dataset.username;
			const apiKey = card?.dataset.apikey;

			if (!username || !apiKey) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const res = await fetch(
				`https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${username}&api_key=${apiKey}&format=json&limit=6`
			);

			if (!res.ok) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const data = await res.json();
			const tracks = data.recenttracks?.track;

			if (skeleton && card && tracks && tracks.length > 0) {
				let trackData = tracks[0];
				const isPlaying = trackData["@attr"]?.nowplaying === "true";

				if (isPlaying) {
					trackData.cachedAt = Date.now();
					localStorage.setItem("lastfm-nowplaying", JSON.stringify(trackData));
				} else {
					const cached = localStorage.getItem("lastfm-nowplaying");
					if (cached) {
						try {
							const cachedTrack = JSON.parse(cached);
							const lastScrobbleTime = parseInt(trackData.date?.uts || "0") * 1000;
							if (
								cachedTrack.cachedAt &&
								cachedTrack.cachedAt > lastScrobbleTime &&
								cachedTrack.name !== trackData.name
							) {
								trackData = cachedTrack;
							}
						} catch (e) {
							console.error("Error parsing cached Last.fm data", e);
						}
					}
				}

				skeleton.classList.add("hidden");
				card.classList.remove("hidden");
				card.classList.add("flex");

				const image =
					trackData.image?.find((img: any) => img.size === "extralarge")?.["#text"] ||
					trackData.image?.[trackData.image.length - 1]?.["#text"];

				const art = document.getElementById("lastfm-art") as HTMLImageElement;
				const statusDot = document.getElementById("lastfm-status-dot");
				const statusText = document.getElementById("lastfm-status");
				const track = document.getElementById("lastfm-track");
				const artist = document.getElementById("lastfm-artist");
				const link = document.getElementById("lastfm-link") as HTMLAnchorElement;

				if (art)
					art.src =
						image ||
						"https://lastfm.freetls.fastly.net/i/u/64s/4128a6eb29f94943c9d206c08e625904.webp";
				if (track) track.textContent = trackData.name;
				if (artist) artist.textContent = trackData.artist?.["#text"] || "Unknown Info";
				
				if (link && trackData.url) {
					link.href = trackData.url;
				} else if (link) {
					link.removeAttribute("href");
				}

				// Hover Card Logic
				const hoverTitle = document.getElementById("hover-status-title");
				const hoverArt = document.getElementById("hover-art") as HTMLImageElement;
				const hoverTrackText = document.getElementById("hover-track");
				const hoverArtistText = document.getElementById("hover-artist");
				const hoverTime = document.getElementById("hover-time");

				if (hoverTitle && hoverArt && hoverTrackText && hoverArtistText && hoverTime) {
					hoverArt.src = image || "https://lastfm.freetls.fastly.net/i/u/64s/4128a6eb29f94943c9d206c08e625904.webp";
					hoverTrackText.textContent = trackData.name;
					hoverArtistText.textContent = trackData.artist?.["#text"] || "Unknown Info";

					let dateStr = "Unknown time";
					if (isPlaying) {
						hoverTitle.textContent = "NOW PLAYING";
						dateStr = new Date().toLocaleString('en-US');
					} else {
						hoverTitle.textContent = "NOT PLAYING";
						if (trackData.date && trackData.date.uts) {
							const d = new Date(parseInt(trackData.date.uts) * 1000);
							dateStr = d.toLocaleString('en-US');
						}
					}
					hoverTime.textContent = `Last listened ${dateStr}`;
				}

				const toggleHistoryBtn = document.getElementById("open-history-btn");
				const historyDropdown = document.getElementById("history-dropdown");
				if (toggleHistoryBtn && historyDropdown) {
					const newBtn = toggleHistoryBtn.cloneNode(true) as HTMLButtonElement;
					toggleHistoryBtn.parentNode?.replaceChild(newBtn, toggleHistoryBtn);
					
					newBtn.addEventListener("click", (e) => {
						e.preventDefault();
						e.stopPropagation();
						historyDropdown.classList.toggle("hidden");
						historyDropdown.classList.toggle("flex");
						if(historyDropdown.classList.contains("flex")) {
							newBtn.textContent = "HIDE LISTENING HISTORY";
						} else {
							newBtn.textContent = "CLICK TO OPEN LISTENING HISTORY";
						}
					});
				}

				if (statusDot && statusText) {
					if (isPlaying) {
						statusDot.className = "h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse";
						statusText.textContent = "PLAYING";
						statusText.className = "text-[10px] font-bold tracking-widest text-green-500 uppercase font-mono";
					} else {
						statusDot.className = "h-1.5 w-1.5 rounded-full bg-amber-500";
						statusText.textContent = "PAUSED";
						statusText.className = "text-[10px] font-bold tracking-widest text-amber-500 uppercase font-mono";
					}
				}

				// Populate recently played list
				const recentList = document.getElementById("lastfm-recent-list");
				if (recentList && tracks.length > 1) {
					// Exclude the currently playing/paused track which is at index 0
					const historyTracks = tracks.slice(1, 6);
					recentList.innerHTML = historyTracks.map((t: any) => {
						const img = t.image?.find((i: any) => i.size === "medium")?.["#text"] || "https://lastfm.freetls.fastly.net/i/u/64s/4128a6eb29f94943c9d206c08e625904.webp";
						const url = t.url || "#";
						const trackName = t.name;
						const artistName = t.artist?.["#text"] || "Unknown";
						
						let timeString = "Unknown";
						if (t.date && t.date.uts) {
							const diffSec = Math.floor(Date.now() / 1000) - parseInt(t.date.uts);
							if (diffSec < 60) timeString = "Just now";
							else if (diffSec < 3600) timeString = `${Math.floor(diffSec/60)}m ago`;
							else if (diffSec < 86400) timeString = `${Math.floor(diffSec/3600)}h ago`;
							else timeString = `${Math.floor(diffSec/86400)}d ago`;
						}

						return `
							<a href="${url}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 hover:bg-[#2b2d31] p-2 -mx-2 rounded-lg transition-colors group/item cursor-pointer">
								<img src="${img}" alt="Art" class="h-8 w-8 rounded shrink-0 object-cover shadow-sm bg-[#2b2d31]" />
								<div class="flex flex-col min-w-0">
									<span class="text-xs font-semibold text-gray-200 truncate group-hover/item:text-white transition-colors">${trackName}</span>
									<div class="flex items-center gap-2 text-[10px] text-[#B5BAC1] mt-0.5">
										<span class="truncate">${artistName}</span>
										<span class="shrink-0 opacity-70">&bull; ${timeString}</span>
									</div>
								</div>
							</a>
						`;
					}).join("");
				}
			} else if (skeleton) {
				skeleton.classList.add("hidden");
			}
		} catch (e) {
			console.error("Error fetching Last.fm info", e);
			const skeleton = document.getElementById("lastfm-skeleton");
			if (skeleton) skeleton.classList.add("hidden");
		}
	}

	// Initial fetch
	fetchLastFm();

	// Poll Last.fm API every 30 seconds for real-time updates
	setInterval(fetchLastFm, 30000);
</script>
