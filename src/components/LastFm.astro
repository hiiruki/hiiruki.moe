---
import { Icon } from "astro-icon/components";

const username = import.meta.env.LASTFM_USERNAME || "";
const apiKey = import.meta.env.LASTFM_API_KEY || "";
---

<div id="lastfm-card" class="mt-8 hidden items-center gap-4" data-username={username} data-apikey={apiKey}>
	<img
		id="lastfm-art"
		src=""
		alt="Album Art"
		class="h-16 w-16 shrink-0 rounded-xl bg-black/10 object-cover shadow-sm dark:bg-white/10"
	/>
	<div class="flex flex-col justify-center gap-1.5">
		<div class="flex items-center gap-2">
			<div id="lastfm-status-dot" class="h-1.5 w-1.5 rounded-full bg-amber-500"></div>
			<span
				id="lastfm-status"
				class="text-[10px] font-bold tracking-widest text-amber-500 uppercase font-mono"
				>PAUSED</span
			>
		</div>
		<a
			id="lastfm-link"
			href="#"
			target="_blank"
			rel="noopener noreferrer"
			class="text-sm font-mono opacity-80 hover:opacity-100 hover:text-accent transition-colors"
		>
			<span id="lastfm-track">Track</span> - <span id="lastfm-artist">Artist</span>
		</a>
	</div>
</div>

<div id="lastfm-skeleton" class="mt-8 flex animate-pulse items-center gap-4">
	<div class="h-16 w-16 shrink-0 rounded-xl bg-black/10 dark:bg-white/10"></div>
	<div class="flex w-full flex-col justify-center gap-2">
		<div class="flex items-center gap-2">
			<div class="h-1.5 w-1.5 rounded-full bg-black/10 dark:bg-white/10"></div>
			<div class="h-2 w-16 rounded bg-black/10 dark:bg-white/10"></div>
		</div>
		<div class="h-3 w-48 rounded bg-black/10 dark:bg-white/10"></div>
	</div>
</div>

<script>
	async function fetchLastFm() {
		try {
			const skeleton = document.getElementById("lastfm-skeleton");
			const card = document.getElementById("lastfm-card");

			const username = card?.dataset.username;
			const apiKey = card?.dataset.apikey;

			if (!username || !apiKey) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const res = await fetch(
				`https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${username}&api_key=${apiKey}&format=json&limit=1`
			);

			if (!res.ok) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const data = await res.json();
			const tracks = data.recenttracks?.track;

			if (skeleton && card && tracks && tracks.length > 0) {
				let trackData = tracks[0];
				const isPlaying = trackData["@attr"]?.nowplaying === "true";

				if (isPlaying) {
					trackData.cachedAt = Date.now();
					localStorage.setItem("lastfm-nowplaying", JSON.stringify(trackData));
				} else {
					const cached = localStorage.getItem("lastfm-nowplaying");
					if (cached) {
						try {
							const cachedTrack = JSON.parse(cached);
							const lastScrobbleTime = parseInt(trackData.date?.uts || "0") * 1000;
							if (
								cachedTrack.cachedAt &&
								cachedTrack.cachedAt > lastScrobbleTime &&
								cachedTrack.name !== trackData.name
							) {
								trackData = cachedTrack;
							}
						} catch (e) {
							console.error("Error parsing cached Last.fm data", e);
						}
					}
				}

				skeleton.classList.add("hidden");
				card.classList.remove("hidden");
				card.classList.add("flex");

				const image =
					trackData.image?.find((img: any) => img.size === "extralarge")?.["#text"] ||
					trackData.image?.[trackData.image.length - 1]?.["#text"];

				const art = document.getElementById("lastfm-art") as HTMLImageElement;
				const statusDot = document.getElementById("lastfm-status-dot");
				const statusText = document.getElementById("lastfm-status");
				const track = document.getElementById("lastfm-track");
				const artist = document.getElementById("lastfm-artist");
				const link = document.getElementById("lastfm-link") as HTMLAnchorElement;

				if (art)
					art.src =
						image ||
						"https://lastfm.freetls.fastly.net/i/u/64s/4128a6eb29f94943c9d206c08e625904.webp";
				if (track) track.textContent = trackData.name;
				if (artist) artist.textContent = trackData.artist?.["#text"] || "Unknown Info";
				
				if (link && trackData.url) {
					link.href = trackData.url;
				} else if (link) {
					link.removeAttribute("href");
				}

				if (statusDot && statusText) {
					if (isPlaying) {
						statusDot.className = "h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse";
						statusText.textContent = "PLAYING";
						statusText.className = "text-[10px] font-bold tracking-widest text-green-500 uppercase font-mono";
					} else {
						statusDot.className = "h-1.5 w-1.5 rounded-full bg-amber-500";
						statusText.textContent = "PAUSED";
						statusText.className = "text-[10px] font-bold tracking-widest text-amber-500 uppercase font-mono";
					}
				}
			} else if (skeleton) {
				skeleton.classList.add("hidden");
			}
		} catch (e) {
			console.error("Error fetching Last.fm info", e);
			const skeleton = document.getElementById("lastfm-skeleton");
			if (skeleton) skeleton.classList.add("hidden");
		}
	}

	fetchLastFm();
</script>
