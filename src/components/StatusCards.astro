---
import { Icon } from "astro-icon/components";
---

<div class="mt-10 grid gap-4 text-sm sm:grid-cols-2">
	<!-- Discord Status -->
	<div
		id="discord-card"
		class="hidden flex-col justify-center gap-0 rounded-3xl border border-black/10 bg-black/5 px-5 py-4 dark:border-white/5 dark:bg-[#090b10]/40"
	>
		<div class="flex w-full items-center gap-4">
			<div class="relative flex-shrink-0">
				<img
					id="discord-avatar"
					src=""
					alt="Discord Avatar"
					class="h-11 w-11 rounded-full bg-black/10 object-cover dark:bg-white/10"
				/>
				<div
					class="bg-global-bg absolute -right-1 -bottom-1 flex h-4 w-4 items-center justify-center rounded-full"
				>
					<div id="discord-status-dot" class="h-2.5 w-2.5 rounded-full bg-gray-500"></div>
				</div>
			</div>
			<div class="flex min-w-0 flex-col leading-tight">
				<div class="flex items-baseline gap-1.5 truncate">
					<span id="discord-display-name" class="text-accent-2 truncate font-bold tracking-wide"
					></span>
					<span id="discord-username" class="truncate text-xs opacity-60"></span>
				</div>
				<div
					id="discord-custom-status"
					class="mt-0.5 flex hidden items-center gap-1.5 truncate text-xs opacity-80"
				>
					<img id="discord-custom-emoji" src="" alt="" class="hidden h-3.5 w-3.5" />
					<span id="discord-custom-text" class="truncate"></span>
				</div>
			</div>
		</div>
		<div
			id="discord-activity"
			class="mt-3 flex hidden w-full items-center gap-3 border-t border-black/10 pt-3 dark:border-white/5"
		>
			<img
				id="discord-activity-img"
				src=""
				alt="Activity"
				class="hidden h-10 w-10 flex-shrink-0 rounded-md object-cover"
			/>
			<div class="flex min-w-0 flex-col leading-tight">
				<span id="discord-activity-name" class="text-accent-2 truncate text-xs font-bold"></span>
				<span id="discord-activity-details" class="hidden truncate text-[10px] opacity-80"></span>
				<span id="discord-activity-state" class="hidden truncate text-[10px] opacity-60"></span>
			</div>
		</div>
	</div>

	<!-- Discord Skeleton -->
	<div
		id="discord-skeleton"
		class="flex animate-pulse items-center gap-4 rounded-3xl border border-black/10 bg-black/5 px-5 py-4 dark:border-white/5 dark:bg-[#090b10]/40"
	>
		<div class="h-11 w-11 flex-shrink-0 rounded-full bg-black/10 dark:bg-white/10"></div>
		<div class="flex w-full flex-col gap-2">
			<div class="h-3 w-1/2 rounded bg-black/10 dark:bg-white/10"></div>
			<div class="h-2 w-1/3 rounded bg-black/10 dark:bg-white/10"></div>
		</div>
	</div>

	<!-- Spotify Status -->
	<a
		id="spotify-card"
		href="#"
		target="_blank"
		rel="noopener noreferrer"
		class="hidden items-center gap-4 rounded-3xl border border-black/10 bg-black/5 px-5 py-4 transition-colors hover:bg-black/10 dark:border-white/5 dark:bg-[#090b10]/40 dark:hover:bg-white/5"
	>
		<img
			id="spotify-img"
			src=""
			alt="Album Art"
			class="h-11 w-11 flex-shrink-0 rounded-md bg-black/10 object-cover shadow-sm dark:bg-white/10"
		/>
		<div class="flex min-w-0 flex-col leading-tight">
			<div class="flex items-baseline gap-1.5 truncate">
				<span id="spotify-title" class="text-accent-2 truncate font-bold tracking-wide"></span>
				<span id="spotify-artist" class="truncate text-xs opacity-60"></span>
			</div>
			<div class="mt-0.5 flex items-center gap-1.5 text-xs opacity-60">
				<Icon name="mdi:spotify" class="h-3.5 w-3.5 flex-shrink-0 text-green-500" />
				<span id="spotify-status-text" class="truncate">Last Played on Spotify</span>
			</div>
		</div>
	</a>

	<!-- Spotify Skeleton -->
	<div
		id="spotify-skeleton"
		class="flex animate-pulse items-center gap-4 rounded-3xl border border-black/10 bg-black/5 px-5 py-4 dark:border-white/5 dark:bg-[#090b10]/40"
	>
		<div class="h-11 w-11 flex-shrink-0 rounded-md bg-black/10 dark:bg-white/10"></div>
		<div class="flex w-full flex-col gap-2">
			<div class="h-3 w-2/3 rounded bg-black/10 dark:bg-white/10"></div>
			<div class="h-2 w-1/3 rounded bg-black/10 dark:bg-white/10"></div>
		</div>
	</div>
</div>

<script>
	const statusColors: Record<string, string> = {
		online: "bg-emerald-500",
		idle: "bg-amber-400",
		dnd: "bg-rose-400",
		offline: "bg-gray-600",
	};

	async function fetchDiscord() {
		try {
			const discordId = "529270835341426708";
			const res = await fetch(`https://api.lanyard.rest/v1/users/${discordId}`);
			const skeleton = document.getElementById("discord-skeleton");
			const card = document.getElementById("discord-card");

			if (!res.ok) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const { data } = await res.json();

			if (skeleton && card) {
				skeleton.classList.add("hidden");
				card.classList.remove("hidden");
				card.classList.add("flex");

				const avatar = document.getElementById("discord-avatar") as HTMLImageElement;
				const statusDot = document.getElementById("discord-status-dot");
				const displayName = document.getElementById("discord-display-name");
				const username = document.getElementById("discord-username");
				const customStatus = document.getElementById("discord-custom-status");
				const customEmoji = document.getElementById("discord-custom-emoji") as HTMLImageElement;
				const customText = document.getElementById("discord-custom-text");

				if (avatar && data.discord_user.avatar) {
					avatar.src = `https://cdn.discordapp.com/avatars/${discordId}/${data.discord_user.avatar}.png`;
				}

				if (statusDot) {
					statusDot.className = `h-2.5 w-2.5 rounded-full ${statusColors[data.discord_status] || "bg-gray-600"}`;
				}

				if (displayName) displayName.textContent = data.discord_user.display_name;
				if (username) username.textContent = data.discord_user.username;

				// Custom Status (type 4)
				const customActivity = data.activities?.find((a: any) => a.type === 4);
				if (customActivity && customStatus) {
					customStatus.classList.remove("hidden");

					if (customActivity.emoji && customEmoji) {
						customEmoji.classList.remove("hidden");
						customEmoji.src = `https://cdn.discordapp.com/emojis/${customActivity.emoji.id}.png`;
					}

					if (customText) {
						customText.textContent = customActivity.state || "";
					}
				}

				// Rich Presence / Other Activity (type 0: Playing, 1: Streaming, 2: Listening, 3: Watching, 5: Competing)
				const activity = data.activities?.find((a: any) => a.type !== 4 && a.type !== 2); // Discard spotify here if any, using native one on right
				if (activity) {
					const activityDiv = document.getElementById("discord-activity");
					const actImg = document.getElementById("discord-activity-img") as HTMLImageElement;
					const actName = document.getElementById("discord-activity-name");
					const actDetails = document.getElementById("discord-activity-details");
					const actState = document.getElementById("discord-activity-state");

					if (activityDiv) activityDiv.classList.remove("hidden");

					if (activity.assets?.large_image && actImg) {
						actImg.classList.remove("hidden");
						const imageId = activity.assets.large_image;
						if (imageId.startsWith("mp:external/")) {
							actImg.src = `https://media.discordapp.net/external/${imageId.replace("mp:external/", "")}`;
						} else {
							actImg.src = `https://cdn.discordapp.com/app-assets/${activity.application_id}/${imageId}.png`;
						}
					}

					if (actName) actName.textContent = activity.name;

					if (activity.details && actDetails) {
						actDetails.classList.remove("hidden");
						actDetails.textContent = activity.details;
					}

					if (activity.state && actState) {
						actState.classList.remove("hidden");
						actState.textContent = activity.state;
					}
				}
			}
		} catch (e) {
			console.error("Error fetching Discord info", e);
			const skeleton = document.getElementById("discord-skeleton");
			if (skeleton) skeleton.classList.add("hidden");
		}
	}

	async function fetchSpotify() {
		try {
			const res = await fetch("/api/spotify");
			const skeleton = document.getElementById("spotify-skeleton");
			const card = document.getElementById("spotify-card");

			if (!res.ok) {
				if (skeleton) skeleton.classList.add("hidden");
				return;
			}

			const data = await res.json();

			if (skeleton && card) {
				skeleton.classList.add("hidden");
				card.classList.remove("hidden");
				card.classList.add("flex");

				const img = document.getElementById("spotify-img") as HTMLImageElement;
				const title = document.getElementById("spotify-title");
				const artist = document.getElementById("spotify-artist");
				const statusText = document.getElementById("spotify-status-text");

				if (data.title && data.title !== "Not Playing") {
					if (img) img.src = data.albumImageUrl || "";
					if (title) title.textContent = data.title;
					if (artist) artist.textContent = data.artist;
					if (statusText) {
						statusText.textContent = data.isPlaying
							? "Now Playing on Spotify"
							: "Last Played on Spotify";
					}
					if (data.songUrl) {
						(card as HTMLAnchorElement).href = data.songUrl;
					} else {
						card.removeAttribute("href");
					}
				} else {
					if (title) title.textContent = "Not Playing";
					if (artist) artist.textContent = "Spotify";
					card.removeAttribute("href");
				}
			}
		} catch (e) {
			console.error("Error fetching Spotify info", e);
			const skeleton = document.getElementById("spotify-skeleton");
			if (skeleton) skeleton.classList.add("hidden");
		}
	}

	fetchDiscord();
	fetchSpotify();
</script>
